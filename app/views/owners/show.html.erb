<div class="card shadow-sm p-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><%= "#{@owner.first_name} #{@owner.last_name}" %></h2>
    
    <div class="d-flex gap-2">
      <% if policy(@owner).edit? %>
        <%= link_to 'Edit Profile', edit_owner_path(@owner), class: "btn btn-info btn-sm" %>
      <% end %>

      <% if policy(@owner).destroy? %>
        <%= button_to 'Delete', @owner, method: :delete, 
            data: { turbo_confirm: "Are you sure?" }, 
            class: "btn btn-danger btn-sm", form_class: "d-inline" %>
      <% end %>

      <%= link_to 'Back to Owners', owners_path, class: "btn btn-outline-secondary btn-sm" %>
    </div>

  </div>
  <hr>
  <p><strong>Email:</strong> <%= @owner.email %></p>
  <p><strong>Phone:</strong> <%= @owner.phone %></p>
  <p><strong>Address:</strong> <%= @owner.address %></p>

  <h3 class="mt-4">Pets</h3>
  <table class="table table-sm mt-2">
    <thead class="table-light">
      <tr>
        <th>Name</th>
        <th>Species</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @owner.pets.each do |pet| %>
        <tr>
          <td><%= pet.name %></td>
          <td><%= pet.species %></td>
          <td><%= link_to "View Pet", pet_path(pet), class: "btn btn-link btn-sm p-0" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

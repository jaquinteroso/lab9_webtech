<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Appointments</h1>
 
  <% if policy(Appointment).new? %>
    <%= link_to "New Appointment", new_appointment_path, class: "btn btn-primary" %>
  <% end %>
</div>

<table class="table table-striped table-hover shadow-sm">
  <thead class="table-dark">
    <tr>
      <th>Date</th>
      <th>Pet Name</th>
      <th>Vet Name</th>
      <th>Reason</th>
      <th>Status</th>
      <th class="text-center">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @appointments.each do |appointment| %>
      <tr>
        <td><%= appointment.date.strftime("%B %d, %Y") %></td>
        
        <td><%= link_to appointment.pet.name, pet_path(appointment.pet) %></td>
        <td><%= link_to "#{appointment.vet.first_name} #{appointment.vet.last_name}", vet_path(appointment.vet) %></td>
        
        <td><%= appointment.reason %></td>
        
        <td>
          <span class="badge bg-secondary">
            <%= appointment.status.titleize %>
          </span>
        </td>
        
        <td class="text-center">
          <div class="d-flex justify-content-center gap-1">
            <%= link_to "View Details", appointment_path(appointment), class: "btn btn-sm btn-outline-primary" %>
            
            <% if policy(appointment).edit? %>
              <%= link_to "Edit", edit_appointment_path(appointment), class: "btn btn-sm btn-info" %>
            <% end %>
            
            <% if policy(appointment).destroy? %>
              <%= button_to "Delete", appointment_path(appointment), 
                  method: :delete, 
                  data: { turbo_confirm: "Are you sure you want to cancel this appointment?" }, 
                  class: "btn btn-sm btn-danger", form_class: "d-inline" %>
            <% end %>
          </div>

        </td>
      </tr>
    <% end %>
  </tbody>
</table>

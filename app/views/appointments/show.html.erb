<div class="card shadow-sm p-4">
  <div class="d-flex justify-content-between align-items-center">
    <h2>Appointment Details</h2>

    <div class="d-flex gap-2">
      <% if policy(@appointment).edit? %>
        <%= link_to "Edit Appointment", edit_appointment_path(@appointment), class: "btn btn-info" %>
      <% end %>
      
      <% if policy(@appointment).destroy? %>
        <%= button_to "Cancel Appointment", appointment_path(@appointment), 
            method: :delete, 
            data: { turbo_confirm: "Are you sure you want to cancel this appointment?" }, 
            class: "btn btn-danger",
            form_class: "d-inline" %>
      <% end %>
    </div>

  </div>
  <hr>
  
  <div class="row">
    <div class="col-md-6">
      <p><strong>Date:</strong> <%= @appointment.date.strftime("%B %d, %Y") %></p>
      <p><strong>Pet:</strong> <%= link_to @appointment.pet.name, pet_path(@appointment.pet) %></p>
      <p><strong>Vet:</strong> <%= link_to @appointment.vet.first_name, vet_path(@appointment.vet) %></p>
    </div>
    <div class="col-md-6">
      <p><strong>Reason:</strong> <%= @appointment.reason %></p>
      <p><strong>Status:</strong> <span class="badge bg-secondary"><%= @appointment.status.titleize %></span></p>
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-center mt-5 mb-3">

    <h3>Treatments</h3>
    <% if policy(Treatment.new(appointment: @appointment)).create? %>
      <%= link_to "Add Treatment", new_appointment_treatment_path(@appointment), class: "btn btn-success" %>
    <% end %>

  </div>

  <table class="table table-hover mt-2">
    <thead class="table-light">
      <tr>
        <th>Name</th>
        <th>Medication</th>
        <th>Dosage</th>
        <th>Administered At</th>
        <th class="text-center">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if @treatments.any? %>
        <% @treatments.each do |t| %>
          <tr>
            <td><%= t.name %></td>
            <td><%= t.medication %></td>
            <td><%= t.dosage %></td>
            <td><%= t.administered_at.strftime("%I:%M %p") %></td>
            <td class="text-center">

              <div class="d-flex justify-content-center gap-1">
                <% if policy(t).edit? %>
                  <%= link_to "Edit", edit_appointment_treatment_path(@appointment, t), class: "btn btn-sm btn-info" %>
                <% end %>
                
                <% if policy(t).destroy? %>
                  <%= button_to "Remove", appointment_treatment_path(@appointment, t), 
                      method: :delete, 
                      data: { turbo_confirm: "Remove this treatment record?" }, 
                      class: "btn btn-sm btn-danger",
                      form_class: "d-inline" %>
                <% end %>
              </div>

            </td>
          </tr>
          
          <% if t.clinical_notes.present? %>
            <tr>
              <td colspan="5" class="border-top-0 pt-0 pb-3">
                <div class="px-3 py-2 bg-light rounded shadow-sm border-start border-info border-4">
                  <small class="text-uppercase fw-bold text-muted d-block mb-1">Clinical Notes:</small>
                  <div class="trix-content text-break">
                    <%= t.clinical_notes %>
                  </div>
                </div>
              </td>
            </tr>
          <% end %>
        <% end %>
      <% else %>
        <tr>
          <td colspan="5" class="text-center text-muted">No treatments recorded yet.</td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="mt-3">
    <%= link_to "Back to Appointments", appointments_path, class: "btn btn-secondary" %>
  </div>
</div>

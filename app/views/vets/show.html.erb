<div class="card shadow-sm p-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Dr. <%= "#{@vet.first_name} #{@vet.last_name}" %></h2>
    
    <div class="d-flex gap-2">
      <% if policy(@vet).edit? %>
        <%= link_to 'Edit Profile', edit_vet_path(@vet), class: "btn btn-info btn-sm" %>
      <% end %>

      <% if policy(@vet).destroy? %>
        <%= button_to 'Delete', @vet, method: :delete, 
            data: { turbo_confirm: "Are you sure?" }, 
            class: "btn btn-danger btn-sm", form_class: "d-inline" %>
      <% end %>

      <%= link_to 'Back to Vets', vets_path, class: "btn btn-outline-secondary btn-sm" %>
    </div>
  </div>
  <hr>
  <p><strong>Email:</strong> <%= @vet.email %></p>
  <p><strong>Phone:</strong> <%= @vet.phone %></p>
  <p><strong>Specialization:</strong> <%= @vet.specialization %></p>

  <h3 class="mt-4">Scheduled Appointments</h3>
  <table class="table table-sm mt-2">
    <thead class="table-light">
      <tr>
        <th>Date</th>
        <th>Pet</th>
        <th>Reason</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% policy_scope(@vet.appointments).each do |app| %>
        <tr>
          <td><%= app.date.strftime("%B %d, %Y") %></td>
          <td>
            <% if policy(app.pet).show? %>
              <%= link_to app.pet.name, pet_path(app.pet) %>
            <% else %>
              <%= app.pet.name %>
            <% end %>
          </td>
          <td><%= app.reason %></td>
          <td>
            <% if policy(app).show? %>
              <%= link_to "View", appointment_path(app), class: "btn btn-link btn-sm p-0" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <h3 class="mt-4">Upcoming Appointments</h3>
  <ul>
    <% policy_scope(@vet.appointments).upcoming.each do |app| %> 
      <li><%= app.date.strftime("%B %d") %> - Pet: <%= app.pet.name %></li>
    <% end %>
  </ul>

  <h3 class="mt-4">Past Consultations</h3>
  <ul>
    <% policy_scope(@vet.appointments).past.each do |app| %>
      <li><%= app.date.strftime("%B %d, %Y") %> - <%= app.pet.name %></li>
    <% end %>
  </ul>
</div>
